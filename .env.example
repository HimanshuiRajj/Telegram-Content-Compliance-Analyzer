# Telegram API Credentials (Get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# OpenAI API Key (Get from https://platform.openai.com)
OPENAI_API_KEY=your_openai_key_here

# Application Settings
APP_NAME=Telegram Content Compliance Analyzer
APP_VERSION=1.0.0

# Storage Configuration
STORAGE_PATH=./storage
LOG_PATH=./storage/logs
SESSION_PATH=./storage/sessions
EVIDENCE_PATH=./storage/evidence
EXPORT_PATH=./storage/exports
CACHE_PATH=./storage/cache

# Session Encryption
SESSION_ENCRYPTION_KEY=your_encryption_key_here_generate_with_secrets_module

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# AI Analysis Settings
OPENAI_MODEL=gpt-4-turbo-preview
ANALYSIS_TIMEOUT=30

# Performance
MAX_MESSAGES_PER_SCAN=5000
BATCH_SIZE=100
WORKER_THREADS=4

# Security
ENABLE_AUDIT_LOG=true
ENABLE_ENCRYPTION=true
